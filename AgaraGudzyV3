health-check:
  enable: true
  lazy: true
  timeout: 1500
  url: http://www.gstatic.com/generate_204
  
tcp-concurrent: false

proxy-providers:
  zapasList:
    type: http
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/ProxyWhiteList.yaml
    interval: 21600
    path: ./providers/zapasList.yaml

  WARPStandart:
    type: http
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/WARPStandart.yaml
    interval: 21600
    path: ./providers/WARPStandart.yaml    

  WARPServerList:
    type: http
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/WARPServer
    interval: 21600
    path: ./providers/WARPServerList.yaml

proxy-groups:
  - name: VPN
    type: select
    interval: 800
    url: http://www.gstatic.com/generate_204
    icon: https://psv4.userapi.com/s/v1/d2/myYi0zo7FBs5-0OC_n9gCfGlX1fEp93vU1GXg092p-4eWEmkWcvSUKPOFtIPUL2Pbdreb4hSP5eZexSjQdK7wHda_MhypBmD-3Z_Z72m0_1K8iZ6o-BLXrIX3neC9lR-EpC2PJ8qPkqN/chebur.png
    proxies:
#градация от лучшего до худшего варианта использования      
      - WARP If
      - Server WARP
      - WARP Discord
      - zapas
    use:
#Нужно для отображения отдельных списков WARP      
      - WARPServerList

#Запасной вариант на случай нестабильности WARP
  - name: WARP If
    type: fallback
    interval: 300
    hidden: true
    url: http://www.gstatic.com/generate_204
    proxies:
      - WARP
      - Server WARP
      - zapas

  - name: WARP
    type: fallback
    interval: 450
    hidden: false
    url: http://www.gstatic.com/generate_204
    use:
      - WARPStandart
      
#WARP с серверами переконвертированные из AWG
  - name: Server WARP
    type: fallback
    interval: 50
    hidden: true
    url: http://www.gstatic.com/generate_204
    use:
      - WARPServerList

  - name: WARP Discord
    type: url-test
    interval: 10
    hidden: true
    url: http://gateway-us-east1-d.discord.gg
    filter: "WARP PL|WARP PL2"
    use:
      - WARPServerList
    proxies:
      - WARP
    auto-fallback: true

#Белые списки 
  - name: zapas
    type: fallback
    interval: 420
    url: http://www.gstatic.com/generate_204
    icon: https://psv4.userapi.com/s/v1/d2/JzoTqn_sF-pyaVhhfrdzgNO9UJZPAHOkiY0Qtp-56c-j_TXwNjNgXaNKolcUOHEUHMnuQxWB1s8RWl9UlkD0rMpiFZVuyVx0dgPEurn2yOjdDppkKpLS3wXzAyx-7i2tqdZS2mtdRwJE/TsrsheuDshye.png
    use:
      - 'zapasList'

rule-providers:
  RulesZapas:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/RulesZapas.yaml
    path: ./rules/RulesZapas.yaml
    interval: 21600

  RulesVPN:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/RulesVPN.yaml
    path: ./rules/RulesVPN.yaml
    interval: 21600
 
  RulesDIRECT:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/RulesDirect.yaml
    path: ./rules/RulesDIRECT.yaml
    interval: 21600
  
  RulesVPNexe:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/JollyDogy/AgaraGudzy/refs/heads/main/rulesVPNexe.yaml
    path: ./rules/RulesVPNexe.yaml
    interval: 21600  

rules:
#Короткие правила
  - DOMAIN-KEYWORD,animegorus.ru,VPN
  - DOMAIN-KEYWORD,ru.yummyani.me,VPN
  - PROCESS-NAME,discord.exe,WARP Discord
#Правила для прямых соединений
  - RULE-SET,RulesDIRECT,DIRECT
#Отдельные правила для исполняемых файлов файлов 
  - RULE-SET,RulesVPNexe,Server WARP
#Запасные правила на случай отказа работы от WARP
  - RULE-SET,RulesZapas,Server WARP
#Основные правила для обхода
  - RULE-SET,RulesVPN,VPN
